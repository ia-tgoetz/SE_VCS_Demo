{
  "custom": {},
  "params": {
    "instancePath": "[default]Tank100"
  },
  "propConfig": {
    "params.instancePath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 373,
      "width": 224
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "header"
        },
        "position": {
          "basis": "32px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "instancePath": "{view.params.instancePath}"
                },
                "tagPath": "{instancePath}.Name"
              },
              "type": "tag"
            }
          }
        },
        "props": {
          "style": {
            "margin": "4px"
          },
          "textStyle": {
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Vessel"
        },
        "position": {
          "basis": "406px"
        },
        "propConfig": {
          "props.value.value": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "instancePath": "{view.params.instancePath}"
                },
                "tagPath": "{instancePath}/level_PV"
              },
              "type": "tag"
            }
          }
        },
        "props": {
          "label": {
            "location": "hidden"
          },
          "style": {
            "margin": "4px"
          },
          "value": {}
        },
        "type": "ia.symbol.vessel"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50%"
            },
            "props": {
              "text": "Temp PV",
              "textStyle": {
                "textAlign": "right"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "marginLeft": "2px",
                "marginRight": "2px"
              },
              "text": ":"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_1"
            },
            "position": {
              "basis": "50%"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "instancePath": "{view.params.instancePath}"
                    },
                    "tagPath": "{instancePath}/temp_PV"
                  },
                  "transforms": [
                    {
                      "expression": "numberFormat({value},\"#,##0.00\") + \" \" +tag({view.params.instancePath}+\"/temp_PV.EngUnit\")",
                      "type": "expression"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "ProcessTemp"
        },
        "position": {
          "basis": "32px",
          "shrink": 0
        },
        "props": {
          "style": {
            "margin": "4px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50%"
            },
            "props": {
              "text": "Temp SP",
              "textStyle": {
                "textAlign": "right"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "marginLeft": "2px",
                "marginRight": "2px"
              },
              "text": ":"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "NumericEntryField"
                },
                "position": {
                  "basis": "50%",
                  "grow": 1
                },
                "propConfig": {
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "fallbackDelay": 2.5,
                        "mode": "indirect",
                        "references": {
                          "instancePath": "{view.params.instancePath}"
                        },
                        "tagPath": "{instancePath}/temp_SP"
                      },
                      "type": "tag"
                    }
                  }
                },
                "props": {
                  "align": "left",
                  "format": "#,##0.00"
                },
                "type": "ia.input.numeric-entry-field"
              },
              {
                "meta": {
                  "name": "unit"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "fallbackDelay": 2.5,
                        "mode": "indirect",
                        "references": {
                          "instancePath": "{view.params.instancePath}"
                        },
                        "tagPath": "{instancePath}/temp_PV.EngUnit"
                      },
                      "type": "tag"
                    }
                  }
                },
                "props": {
                  "style": {
                    "marginLeft": "4px"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "FlexContainer"
            },
            "position": {
              "basis": "50%"
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "Process Temp Setpoint"
        },
        "position": {
          "basis": "32px",
          "shrink": 0
        },
        "props": {
          "style": {
            "margin": "4px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "MultiStateButton"
        },
        "position": {
          "basis": "89px",
          "shrink": 0
        },
        "propConfig": {
          "props.controlValue": {
            "binding": {
              "config": {
                "bidirectional": true,
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "instancePath": "{view.params.instancePath}"
                },
                "tagPath": "{instancePath}/HOA"
              },
              "type": "tag"
            }
          },
          "props.indicatorValue": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "instancePath": "{view.params.instancePath}"
                },
                "tagPath": "{instancePath}/HOA"
              },
              "type": "tag"
            }
          }
        },
        "props": {
          "states": [
            {
              "selectedStyle": {
                "backgroundColor": "#FFF275",
                "classes": ""
              },
              "text": "Hand",
              "unselectedStyle": {
                "classes": ""
              },
              "value": 2
            },
            {
              "selectedStyle": {
                "backgroundColor": "#F84553",
                "classes": ""
              },
              "text": "Off",
              "unselectedStyle": {
                "classes": ""
              },
              "value": 0
            },
            {
              "selectedStyle": {
                "backgroundColor": "#7CEA9C",
                "classes": ""
              },
              "text": "Auto",
              "unselectedStyle": {
                "classes": ""
              },
              "value": 1
            }
          ],
          "style": {
            "margin": "4px"
          }
        },
        "type": "ia.input.multi-state-button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "--neutral-30",
        "margin": "4px"
      }
    },
    "type": "ia.container.flex"
  }
}